<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jyfq.loan.mapper.NotifyRecordMapper">

    <!-- 幂等检查 -->
    <select id="existsByInstAndNo" resultType="boolean">
        SELECT COUNT(1) > 0
        FROM notify_record
        WHERE inst_code = #{instCode}
          AND notify_no = #{notifyNo}
    </select>

</mapper>
